#!/usr/bin/env bash
# aictx — devctx protocol CLI
# https://github.com/mzaid101/devctx
set -euo pipefail

VERSION="0.1.0"
DEVCTX_DIR=".aictx"
DEVCTX_FILE="DEVCTX.md"

usage() {
  cat <<HELP
aictx v${VERSION} — devctx protocol CLI

Usage:
  aictx init [agent]   Setup .aictx/, DEVCTX.md, and optional agent rules (claude, cursor, antigravity, lovable)
  aictx graphify       Setup graphify in .aictx/GRAPH.md
  aictx status         Print current context summary
  aictx help           Show this message

HELP
}

cmd_graphify() {
  echo "Graphify: map context." > "$DEVCTX_DIR/GRAPH.md"
  echo "aictx: created $DEVCTX_DIR/GRAPH.md"
}

write_agent_rules() {
  local agent=$1
  local rulefile=""
  case "$agent" in
    claude) rulefile=".clauderules" ;;
    cursor) rulefile=".cursorrules" ;;
    antigravity) rulefile=".antigravityrules" ;;
    lovable) rulefile=".lovablerules" ;;
    *) echo "aictx: unknown agent '${agent}'. Supported: claude, cursor, antigravity, lovable."; return ;;
  esac
  echo "Agent $agent: use caveman style. Save token. Read DEVCTX.md. Support graphify." > "$rulefile"
  echo "aictx: created $rulefile for $agent"
}

cmd_init() {
  local agent="${1:-}"
  if [[ -f "$DEVCTX_FILE" ]]; then
    echo "aictx: $DEVCTX_FILE already exists. Skipping root file."
  else
    write_devctx_md
    echo "aictx: created $DEVCTX_FILE"
  fi

  mkdir -p "$DEVCTX_DIR/decisions" "$DEVCTX_DIR/threads" "$DEVCTX_DIR/open"

  if [[ -f "$DEVCTX_DIR/CURRENT.md" ]]; then
    echo "aictx: $DEVCTX_DIR/CURRENT.md already exists. Skipping."
  else
    write_current_md
    echo "aictx: created $DEVCTX_DIR/CURRENT.md"
  fi

  if [[ -f "$DEVCTX_DIR/HANDOFF.md" ]]; then
    echo "aictx: $DEVCTX_DIR/HANDOFF.md already exists. Skipping."
  else
    write_handoff_md
    echo "aictx: created $DEVCTX_DIR/HANDOFF.md"
  fi

  touch "$DEVCTX_DIR/decisions/.gitkeep" \
        "$DEVCTX_DIR/threads/.gitkeep" \
        "$DEVCTX_DIR/open/.gitkeep"

  echo ""
  echo "Done. devctx is live in this repo."
  echo "  Edit $DEVCTX_DIR/CURRENT.md to set your project state."
  echo "  Commit everything to git."

  if [[ -n "$agent" ]]; then
    write_agent_rules "$agent"
  fi
}

cmd_status() {
  if [[ ! -f "$DEVCTX_DIR/CURRENT.md" ]]; then
    echo "aictx: no $DEVCTX_DIR/CURRENT.md found. Run 'aictx init' first."
    exit 1
  fi
  echo "=== $DEVCTX_DIR/CURRENT.md ==="
  cat "$DEVCTX_DIR/CURRENT.md"
}

write_devctx_md() {
  cat > "$DEVCTX_FILE" <<'DEVCTX'
# devctx
Repo use devctx. Save token. Caveman style.
## Rule
1. Read `.aictx/CURRENT.md`. Fast state.
2. Write `.aictx/HANDOFF.md`. Tell next agent.
## Map
`.aictx/CURRENT.md`: Now.
`.aictx/HANDOFF.md`: Handoff.
`.aictx/decisions/`: Big choice.
`.aictx/threads/`: Chat.
`.aictx/open/`: Blocked.
## Write HANDOFF
End session write:
Handoff - YYYY-MM-DD
Happen: [did]
State: [now]
Next: [do]
Dont touch: [bad]
DEVCTX
}

write_current_md() {
  cat > "$DEVCTX_DIR/CURRENT.md" <<'CURRENT'
tick: — | branch: — | status: —
focus: —
last-decision: —
blocked: —
dont-touch: —
next: —
CURRENT
}

write_handoff_md() {
  cat > "$DEVCTX_DIR/HANDOFF.md" <<'HANDOFF'
# Handoff - —
## Happen
—
## State
—
## Next
—
## Dont touch
—
HANDOFF
}

case "${1:-help}" in
  init)    cmd_init "${2:-}" ;;
  graphify) cmd_graphify ;;
  status)  cmd_status ;;
  help|--help|-h) usage ;;
  version|--version|-v) echo "aictx v${VERSION}" ;;
  *)
    echo "aictx: unknown command '${1}'. Run 'aictx help'." >&2
    exit 1
    ;;
esac
